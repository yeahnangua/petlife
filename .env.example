# Local server
PORT=8787
BASE_URL=http://127.0.0.1:8787
MOBILE_APP_URL=http://127.0.0.1:5173/
ADMIN_KEY=petlife-admin-demo

# WeChat Official Account OAuth
# Use real public HTTPS URLs in BASE_URL and MOBILE_APP_URL when testing with WeChat.
WECHAT_OFFICIAL_ACCOUNT_APP_ID=
WECHAT_OFFICIAL_ACCOUNT_APP_SECRET=
WECHAT_OFFICIAL_ACCOUNT_SCOPE=snsapi_userinfo
WECHAT_OFFICIAL_ACCOUNT_TOKEN=
# Use \n for line breaks in WeChat text replies.
WECHAT_OFFICIAL_ACCOUNT_WELCOME_MESSAGE=欢迎关注 PetLife\nhttps://petlife.20050129.xyz

# Mobile client
# Set to true only when WeChat OAuth is configured; false keeps the demo login button.
VITE_WECHAT_OAUTH_ENABLED=false

# AI recommendation/chat
SILICONFLOW_API_KEY=
SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V4-Flash
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
AI_TIMEOUT_MS=30000
